# Supabase PostgreSQL - Local Development Configuration
# This file is configured for Supabase PostgreSQL database

DJANGO_SECRET_KEY=local-dev-change-before-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Supabase PostgreSQL Database Configuration
# Replace with your actual Supabase credentials:
# 1. Go to https://supabase.com/dashboard
# 2. Select your project
# 3. Go to Project Settings → Database
# 4. Copy the Connection String (URI format)
# Format: postgresql://postgres:[password]@db.[project-id].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:[your-password]@db.sqerzctpeharotzjtyfi.supabase.co:5432/postgres

# Redis Configuration (for local development)
USE_INMEMORY_CHANNELS=True
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0

# JWT Token Configuration
ACCESS_TOKEN_MINUTES=30
REFRESH_TOKEN_DAYS=7

# AI Configuration
AI_PROVIDER=local
AI_ENABLED=False
ANTHROPIC_API_KEY=

# Optional: GitHub, Vercel, AWS, Netlify tokens
GITHUB_TOKEN=
VERCEL_API_TOKEN=
VERCEL_TEAM_ID=
VERCEL_CACHE_SECONDS=45
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
NETLIFY_API_TOKEN=
DIGITALOCEAN_API_TOKEN=
FIELD_ENCRYPTION_KEY=
