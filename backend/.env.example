DJANGO_SECRET_KEY=replace-this-secret-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,*
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
FRONTEND_URL=http://localhost:5173

DB_NAME=manageai.sqlite3
# Railway/PostgreSQL production:
# DATABASE_URL=${{Postgres.DATABASE_URL}}
# DB_CONN_MAX_AGE=60
# DB_SSLMODE=require

MEDIA_URL=/media/
# Railway volume production:
# MEDIA_ROOT=${{RAILWAY_VOLUME_MOUNT_PATH}}/media
# SERVE_MEDIA_FILES=True

USE_INMEMORY_CHANNELS=True
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_CACHE_URL=redis://127.0.0.1:6379/1
# Cloud Redis example (TLS): rediss://default:YOUR_URL_ENCODED_PASSWORD@host:port/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0
ACCESS_TOKEN_MINUTES=30
REFRESH_TOKEN_DAYS=7
AI_PROVIDER=local
AI_ENABLED=False
ANTHROPIC_API_KEY=
FIELD_ENCRYPTION_KEY=
GITHUB_TOKEN=
VERCEL_API_TOKEN=
VERCEL_TEAM_ID=
VERCEL_CACHE_SECONDS=45
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
NETLIFY_API_TOKEN=
DIGITALOCEAN_API_TOKEN=
